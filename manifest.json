{
  "manifest_version": 3,
  "name": "Video Speed Freestyle by Qiushi",
  "short_name": "SpeedStyle",
  "version": "1.2.1",
  "description": "Freestyle HTML5 video playback speed with global, per-tab, and hold-to-speed controls.",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_title": "Video Speed Freestyle by Qiushi",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
